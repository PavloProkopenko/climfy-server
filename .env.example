# Server
PORT=3001

# Supabase (get from supabase.com → Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # used only for auth.getUser()
SUPABASE_ANON_KEY=your-anon-key                   # used for all DB queries (respects RLS)

# OpenWeatherMap (same key as frontend)
OPENWEATHER_API_KEY=your-openweathermap-api-key

# Anthropic (get from console.anthropic.com)
ANTHROPIC_API_KEY=your-anthropic-api-key

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000
